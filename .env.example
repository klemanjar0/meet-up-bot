# Copy this file to .env and fill in the values.

# --- Telegram ---
# Token from @BotFather.
TELEGRAM_BOT_TOKEN=

# --- Postgres (used by docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meetup
POSTGRES_PORT=5432

# --- Application ---
# DATABASE_URL is assembled from the POSTGRES_* vars for docker-compose.
# For running the bot on your host against the compose DB, use:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/meetup?sslmode=disable

# development (colorized console logs) or production (JSON logs)
APP_ENV=development
# debug | info | warn | error
LOG_LEVEL=info
